---
import type { Referencia } from '@/data/referencias'
import { FileText, ExternalLink } from 'lucide-react'
import { cardVariants } from '@/lib/card-variants'

const { item } = Astro.props as { item: Referencia }
const isExternal = item.url.startsWith('http')
const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
const thumbnailSrc = item.thumbnail ? `${base}/${item.thumbnail.replace(/^\/+/, '')}` : null
const resolvedUrl = isExternal ? item.url : `${base}/${item.url.replace(/^\/+/, '')}`

const tipoAccent = {
  normativo: { ring: 'ring-institucional-blue/20', bg: 'from-institucional-blue/10 to-institucional-lightBlue/20', icon: 'text-institucional-blue dark:text-blue-300' },
  documento: { ring: 'ring-institucional-blue/20', bg: 'from-institucional-blue/10 to-institucional-lightBlue/20', icon: 'text-institucional-blue dark:text-blue-300' },
  portal:    { ring: 'ring-institucional-green/20', bg: 'from-institucional-green/10 to-institucional-lightGreen/20', icon: 'text-institucional-green dark:text-green-400' },
}[item.tipo] ?? { ring: 'ring-institucional-blue/20', bg: 'from-institucional-blue/10 to-institucional-green/10', icon: 'text-slate-400' }
---

<a
  href={resolvedUrl}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
  class={[cardVariants({ variant: 'default', accent: item.tipo === 'portal' ? 'green' : 'blue' }), 'group block p-5 no-underline'].join(' ')}
>
  <div class="flex items-start gap-4">
    <div class={`shrink-0 w-16 h-20 rounded-lg overflow-hidden flex items-center justify-center bg-gradient-to-br ${tipoAccent.bg} ring-1 ${tipoAccent.ring}`}>
      {thumbnailSrc ? (
        <img src={thumbnailSrc} alt={item.titulo} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <FileText className={`w-6 h-6 ${tipoAccent.icon}`} />
      )}
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <span class="text-xs font-semibold uppercase tracking-wider text-institucional-blue dark:text-blue-300">{item.tipo}</span>
        {isExternal && <ExternalLink className="w-3 h-3 text-slate-400" />}
      </div>
      <h3 class="text-base font-bold text-slate-800 dark:text-white group-hover:text-institucional-blue dark:group-hover:text-blue-300 transition-colors">
        {item.titulo}
      </h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-1 line-clamp-2">{item.descricao}</p>
      <div class="flex flex-wrap gap-1.5 mt-3">
        {item.tags.map(tag => (
          <span class="inline-block px-2 py-0.5 text-[11px] font-medium rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
