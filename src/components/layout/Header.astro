---
import { SECOES } from '@/lib/constants'
import { SearchBox } from '@/components/react/content/SearchBox'
const current = Astro.url.hash?.replace('#', '') || 'inicio'
const base = import.meta.env.BASE_URL
---

<header class="sticky top-0 z-50 bg-white/95 dark:bg-slate-900/95 backdrop-blur border-b border-slate-200 dark:border-slate-800">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={base || '/'} class="flex items-center gap-3 shrink-0 no-underline">
      <img src={`${base}images/logo_coovig.svg`} alt="COOVIG" class="h-8 w-auto" />
      <div class="hidden sm:block">
        <p class="text-xs font-semibold text-institucional-blue dark:text-blue-300 leading-tight">COOVIG / SEDSODH</p>
        <p class="text-[11px] text-slate-500 dark:text-slate-400 leading-tight">Vigilância Socioassistencial</p>
      </div>
    </a>

    <div class="hidden md:block flex-1 max-w-sm mx-4">
      <SearchBox client:idle placeholder="Buscar normativos, materiais..." />
    </div>

    <nav class="flex items-center gap-1" aria-label="Navegação principal">
      {SECOES.map(({ id, label }) => (
        <a
          href={`#${id}`}
          class:list={[
            'px-3 py-2 text-sm font-medium rounded-lg transition-colors',
            current === id
              ? 'bg-institucional-blue text-white dark:bg-blue-600'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100 dark:text-slate-400 dark:hover:text-white dark:hover:bg-slate-800',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>
