---
const base = import.meta.env.BASE_URL
---
<footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <img src={`${base}images/logo_coovig.svg`} alt="COOVIG" class="h-8 w-auto" />
        <div class="text-xs text-slate-500 dark:text-slate-400">
          <p class="font-semibold text-slate-600 dark:text-slate-300">COOVIG — Coordenação Estadual de Vigilância Socioassistencial</p>
          <p>SEDSODH — Secretaria de Estado de Desenvolvimento Social e Direitos Humanos</p>
          <p class="mt-1">Governo do Estado do Rio de Janeiro</p>
        </div>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-500">Versão 1.0 — 2026</p>
    </div>
  </div>
</footer>
