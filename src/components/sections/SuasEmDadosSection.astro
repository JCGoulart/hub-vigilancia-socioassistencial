---
import Section from '@/components/layout/Section.astro'
import SitePreviewModal from '@/components/react/SitePreviewModal'

const { variant } = Astro.props
---

<Section id="suas-em-dados" title="SUAS em Dados" variant={variant}>
  <div class="relative bg-gradient-to-br from-institucional-blue via-blue-700 to-indigo-800 dark:from-blue-950 dark:via-slate-900 dark:to-indigo-950 rounded-2xl p-8 md:p-12 text-white shadow-xl ring-1 ring-white/10 overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl" />
    <div class="absolute bottom-0 left-0 w-48 h-48 bg-blue-400/10 rounded-full translate-y-1/3 -translate-x-1/4 blur-2xl" />
    <div class="relative flex flex-col lg:flex-row lg:items-center gap-8">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-400/20 text-emerald-200 text-xs font-bold uppercase tracking-wider mb-5 ring-1 ring-emerald-400/30">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" />
          Sistema desenvolvido pela COOVIG
        </div>
        <h3 class="text-3xl md:text-4xl font-extrabold mb-4 leading-tight">
          SUAS em Dados
        </h3>
        <p class="text-blue-100/90 leading-relaxed max-w-2xl text-base md:text-lg">
          Plataforma interativa de visualização e consulta de dados do Sistema Único de Assistência Social.
          Desenvolvida pela equipe da COOVIG para apoiar a tomada de decisão baseada em evidências
          nos municípios do Estado do Rio de Janeiro.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a
            href="https://suas-em-dados.cloud/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-white text-institucional-blue font-bold text-base hover:bg-blue-50 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 shadow-md no-underline"
          >
            Acessar Plataforma
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="https://suas-em-dados.cloud/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 rounded-xl bg-white/10 text-white font-semibold text-base hover:bg-white/20 hover:-translate-y-0.5 transition-all duration-200 ring-1 ring-white/20 no-underline"
          >
            Saiba mais
          </a>
        </div>
      </div>
      <div class="hidden lg:block shrink-0">
        <SitePreviewModal
          client:visible
          url="https://suas-em-dados.cloud/"
          titulo="SUAS em Dados"
        />
      </div>
    </div>
  </div>
</Section>
