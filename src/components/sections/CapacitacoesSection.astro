---
import Section from '@/components/layout/Section.astro'
import PdfViewerModal from '@/components/react/PdfViewerModal'
import { capacitacoes } from '@/data/capacitacoes'

const { variant } = Astro.props

const capacitacoesPorAno = new Map<number, typeof capacitacoes>()
capacitacoes.forEach(c => {
  const ano = c.ano || 0
  if (!capacitacoesPorAno.has(ano)) capacitacoesPorAno.set(ano, [])
  capacitacoesPorAno.get(ano)!.push(c)
})
const anosOrdenados = [...capacitacoesPorAno.keys()].sort((a, b) => b - a)

const base = import.meta.env.BASE_URL.replace(/\/+$/, '')
---

<Section id="capacitacoes" title="Capacitações" variant={variant}>
  <p class="text-slate-500 dark:text-slate-400 mb-8 max-w-3xl">
    Cursos, seminários e encontros nacionais voltados à capacitação das equipes municipais
    de Vigilância Socioassistencial.
  </p>
  {capacitacoes.length === 0 && (
    <div class="text-center py-12 text-slate-400 dark:text-slate-500">
      <p class="text-lg">Materiais de capacitação em breve.</p>
      <p class="text-sm mt-2">A equipe está preparando os conteúdos.</p>
    </div>
  )}
  <div class="space-y-3">
    {anosOrdenados.map((ano) => (
      <details open={ano === 2026} class="group border border-slate-200 dark:border-slate-700 rounded-xl overflow-hidden">
        <summary class="flex items-center justify-between px-5 py-4 cursor-pointer bg-slate-50 dark:bg-slate-800/50 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors list-none select-none">
          <div class="flex items-center gap-3">
            <span class="text-lg font-bold text-slate-800 dark:text-white">{ano}</span>
            <span class="text-xs text-slate-400 dark:text-slate-500">
              {capacitacoesPorAno.get(ano)!.length} {capacitacoesPorAno.get(ano)!.length === 1 ? 'capacitação' : 'capacitações'}
            </span>
          </div>
          <svg
            class="w-5 h-5 text-slate-400 transition-transform duration-200 group-open:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-5 pt-1">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {capacitacoesPorAno.get(ano)!.map((c) => (
              <PdfViewerModal
                client:visible
                titulo={c.titulo}
                descricao={c.descricao}
                pdfUrl={`${base}${c.url}`}
                tipo={c.tipo}
                data={c.data}
                tags={c.tags}
              />
            ))}
          </div>
        </div>
      </details>
    ))}
  </div>
</Section>
