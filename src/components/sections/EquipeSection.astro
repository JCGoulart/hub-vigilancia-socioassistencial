---
import Section from '@/components/layout/Section.astro'
import TeamCard from '@/components/cards/TeamCard.astro'
import { equipe } from '@/data/equipe'

const { variant } = Astro.props
---

<Section id="equipe" title="Equipe e Contato" variant={variant}>
  <div class="relative overflow-hidden">
    <div class="ambient-glow top-0 right-0 w-48 h-48 bg-institucional-green/8 dark:bg-institucional-green/12 -translate-y-1/3 translate-x-1/4 blur-2xl" />
    <div class="ambient-glow bottom-0 left-1/3 w-56 h-56 bg-institucional-lightBlue/5 dark:bg-institucional-lightBlue/10 translate-y-1/2 -translate-x-1/4" />

  <div class="relative grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 animate-on-scroll stagger">
        {equipe.map(membro => <TeamCard membro={membro} />)}
      </div>
    </div>
    <div class="bg-gradient-to-br from-institucional-green to-green-700 dark:from-green-900 dark:to-slate-800 rounded-2xl p-8 text-white h-fit">
      <h3 class="text-lg font-bold mb-4">Contato</h3>
      <div class="space-y-4 text-green-50">
        <div>
          <p class="text-xs uppercase tracking-wider text-green-200">Contato</p>
          <a href="mailto:coordvigilanciasgs@sedsdh.rj.gov.br" class="text-sm hover:text-white transition-colors block">
            coordvigilanciasgs@sedsdh.rj.gov.br
          </a>
          <a href="tel:+552132313658" class="text-sm hover:text-white transition-colors block mt-1">
            (21) 3231-3658
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-green-200">Endereço</p>
          <p class="text-sm">Praça Pio X, nº 55, 4º andar</p>
          <p class="text-sm">Rio de Janeiro — Centro</p>
        </div>
      </div>
    </div>
  </div>
  </div>

</Section>
